# --- BACKEND CONFIGURATION ---
DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/primus
REDIS_URL=redis://redis:6379/0
SECRET_KEY=PLACEHOLDER_SECRET_KEY
ENVIRONMENT=local # local | production

# --- STORAGE CONFIGURATION (MinIO) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
BACKUP_ENCRYPTION_KEY=XkkN_G-SZUEXzcULZhD3b8w3noM2q_Vt4xBQxmsBDSU=

# --- CELERY & BROKER CONFIGURATION ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883

# --- AI & VOICE CONFIGURATION (Hybrid Mode for WSL2) ---
# Connects to Ollama running on Windows Host
# Provider: 'ollama' or 'openai'
VOICE_LLM_PROVIDER=ollama
OLLAMA_URL=http://host.docker.internal:11434/api/generate
VOICE_LLM_MODEL=qwen3:4b
VOICE_LLM_API_KEY=

# --- SCHEDULES (UTC/Timezone dependent) ---
REPORTS_SCHEDULE_HOUR=13
REPORTS_SCHEDULE_MINUTE=57
BACKUP_SCHEDULE_HOUR=13
BACKUP_SCHEDULE_MINUTE=59
AI_RETRAIN_SCHEDULE_HOUR=2
AI_RETRAIN_SCHEDULE_MINUTE=0

# --- FRONTEND CONFIGURATION ---
VITE_API_URL=http://localhost:8000

# --- POSTGRES CONFIGURATION ---
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=primus