# ==========================================
# PRIMUS 2026 - KONFIGURACJA ŚRODOWISKA
# ==========================================
# Skopiuj ten plik jako `.env` i dostosuj wartości do swojego środowiska.
# Niektóre wartości są domyślne dla Docker Compose i nie wymagają zmiany przy testach.

# --- 1. KONFIGURACJA BACKENDU (FastAPI) ---
# Adres bazy danych PostgreSQL (format: postgresql+asyncpg://user:password@host:port/dbname)
DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/primus

# Adres Redis do cache i kolejki zadań (format: rediss:// dla SSL lub redis:// bez SSL)
REDIS_URL=rediss://redis:6379/0?ssl_cert_reqs=required&ssl_ca_certs=/etc/ssl/certs/rootCA.pem

# Klucz do podpisywania tokenów JWT 
SECRET_KEY=zmien_mnie_na_bezpieczny_klucz_produkcyjny_123

# Tryb środowiska: 'local' (debug on i dostęp do /docs) lub 'production' 
ENVIRONMENT=local

# --- 2. KONFIGURACJA STORAGE (MinIO / S3) ---
# Dane logowania do panelu MinIO i dostępu API
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Klucz symetryczny do szyfrowania backupów (AES Fernet)
# Wygeneruj np. w Pythonie: `from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())`
BACKUP_ENCRYPTION_KEY=XkkN_G-SZUEXzcULZhD3b8w3noM2q_Vt4xBQxmsBDSU=

# --- 3. KONFIGURACJA WORKERA (Celery) ---
# Broker i Backend wyników dla Celery (zazwyczaj to samo co REDIS_URL)
CELERY_BROKER_URL=rediss://redis:6379/0?ssl_cert_reqs=required&ssl_ca_certs=/etc/ssl/certs/rootCA.pem
CELERY_RESULT_BACKEND=rediss://redis:6379/0?ssl_cert_reqs=required&ssl_ca_certs=/etc/ssl/certs/rootCA.pem

# Konfiguracja MQTT (Mosquitto)
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=8883 # Port TLS

# --- 4. KONFIGURACJA AI & VOICE (Ollama / OpenAI) ---
# Wybór modelu: 'ollama' (lokalny) lub 'openai' (chmura)
VOICE_LLM_PROVIDER=ollama

# Adres API Ollama
# - Dla Linux/Docker: http://ollama:11434/api/generate
# - Dla Windows/WSL2 (host): http://host.docker.internal:11434/api/generate
OLLAMA_URL=http://ollama:11434/api/generate

# Nazwa modelu (Ollama pobiera go sam za pierwszym razem)
VOICE_LLM_MODEL=qwen3:4b

# Klucz API (tylko jeśli provider=openai)
VOICE_LLM_API_KEY=

# --- 5. HARMONOGRAM ZADAŃ (UTC) ---
# Godziny uruchamiania cyklicznych zadań przez Celery Beat

# Raporty PDF (np. codziennie o 13:57)
REPORTS_SCHEDULE_HOUR=13
REPORTS_SCHEDULE_MINUTE=57

# Backupy bazy i plików (np. o 13:59)
BACKUP_SCHEDULE_HOUR=13
BACKUP_SCHEDULE_MINUTE=59

# Dotrenowywanie modelu AI (np. o 02:00 w nocy)
AI_RETRAIN_SCHEDULE_HOUR=2
AI_RETRAIN_SCHEDULE_MINUTE=0

# --- 6. KONFIGURACJA FRONTENDU (React) ---
# Adres API widoczny dla przeglądarki (przez NGINX)
VITE_API_URL=https://localhost/api/v1

# --- 7. KONFIGURACJA BAZY DANYCH (Postgres Docker) ---
# Dane inicjalizacji kontenera
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=primus
